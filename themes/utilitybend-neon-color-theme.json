    "tab.activeBorderTop": "#c792ea",

    "panel.background": "#0b0914",
    "panel.border": "#1a1726",
    "panelTitle.activeBorder": "#c792ea",
    "panelTitle.activeForeground": "#eeeeee",
    "panelTitle.inactiveForeground": "#616161",

    "terminal.background": "#0e0c16",
    "terminal.foreground": "#eeeeee",
    "terminal.ansiBlack": "#0e0c16",
    "terminal.ansiRed": "#ff6666",
    "terminal.ansiGreen": "#a5e844",
    "terminal.ansiYellow": "#ffcb6b",
    "terminal.ansiBlue": "#80cbc4",
    "terminal.ansiMagenta": "#c792ea",
    "terminal.ansiCyan": "#80cbc4",
    "terminal.ansiWhite": "#eeeeee",
    "terminal.ansiBrightBlack": "#888888",
    "terminal.ansiBrightRed": "#ff6666",
    "terminal.ansiBrightGreen": "#a5e844",
    "terminal.ansiBrightYellow": "#ffcb6b",
    "terminal.ansiBrightBlue": "#80cbc4",
    "terminal.ansiBrightMagenta": "#e599f7",
    "terminal.ansiBrightCyan": "#80cbc4",
    "terminal.ansiBrightWhite": "#ffffff",
    "terminalCursor.foreground": "#c792ea",

    "input.background": "#13111d",
    "input.foreground": "#eeeeee",
    "input.border": "#2a2640",
    "input.placeholderForeground": "#616161",
    "inputOption.activeBorder": "#c792ea",

    "dropdown.background": "#13111d",
    "dropdown.foreground": "#eeeeee",
    "dropdown.border": "#2a2640",

    "button.background": "#c792ea",
    "button.foreground": "#0e0c16",
    "button.hoverBackground": "#d4a5f0",
    "button.secondaryBackground": "#1a1726",
    "button.secondaryForeground": "#eeeeee",

    "badge.background": "#c792ea",
    "badge.foreground": "#0e0c16",

    "scrollbar.shadow": "#00000044",
    "scrollbarSlider.background": "#ffffff15",
    "scrollbarSlider.hoverBackground": "#ffffff25",
    "scrollbarSlider.activeBackground": "#ffffff35",

    "minimap.selectionHighlight": "#c792ea44",
    "minimap.findMatchHighlight": "#ffcb6b44",
    "minimapGutter.addedBackground": "#a5e844",
    "minimapGutter.deletedBackground": "#ff6666",
    "minimapGutter.modifiedBackground": "#80cbc4",

    "peekView.border": "#c792ea",
    "peekViewEditor.background": "#0b0914",
    "peekViewEditor.matchHighlightBackground": "#ffcb6b33",
    "peekViewResult.background": "#0a0812",
    "peekViewResult.fileForeground": "#eeeeee",
    "peekViewResult.lineForeground": "#888888",
    "peekViewResult.matchHighlightBackground": "#ffcb6b33",
    "peekViewResult.selectionBackground": "#c792ea22",
    "peekViewTitle.background": "#0a0812",
    "peekViewTitleDescription.foreground": "#888888",
    "peekViewTitleLabel.foreground": "#eeeeee",

    "gitDecoration.addedResourceForeground": "#a5e844",
    "gitDecoration.deletedResourceForeground": "#ff6666",
    "gitDecoration.modifiedResourceForeground": "#80cbc4",
    "gitDecoration.untrackedResourceForeground": "#a5e844aa",
    "gitDecoration.conflictingResourceForeground": "#fd9170",
    "gitDecoration.ignoredResourceForeground": "#616161",

    "debugToolBar.background": "#13111d",
    "debugIcon.breakpointForeground": "#ff1493",

    "focusBorder": "#c792ea66",
    "foreground": "#eeeeee",
    "descriptionForeground": "#888888",
    "selection.background": "#c792ea44",
    "widget.shadow": "#00000044",
    "icon.foreground": "#888888",

    "notifications.background": "#13111d",
    "notifications.foreground": "#eeeeee",
    "notifications.border": "#2a2640",
    "notificationCenterHeader.background": "#0a0812",

    "quickInput.background": "#13111d",
    "quickInput.foreground": "#eeeeee",
    "quickInputList.focusBackground": "#c792ea22",

    "editorWidget.background": "#13111d",
    "editorWidget.foreground": "#eeeeee",
    "editorWidget.border": "#2a2640",
    "editorSuggestWidget.background": "#13111d",
    "editorSuggestWidget.foreground": "#eeeeee",
    "editorSuggestWidget.selectedBackground": "#c792ea22",
    "editorSuggestWidget.highlightForeground": "#c792ea",

    "editorHoverWidget.background": "#13111d",
    "editorHoverWidget.border": "#2a2640",

    "diffEditor.insertedTextBackground": "#a5e84415",
    "diffEditor.removedTextBackground": "#ff666615"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#888888",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Doctype, Prolog",
      "scope": [
        "meta.tag.sgml.doctype",
        "meta.tag.sgml",
        "comment.block.html"
      ],
      "settings": {
        "foreground": "#616161"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.definition.tag",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.section"
      ],
      "settings": {
        "foreground": "#faf0e6"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#c792ea"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "support.function.misc.css",
        "support.function.calc.css",
        "support.function.gradient.css",
        "support.function.url.css",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#c792ea"
      }
    },
    {
      "name": "Booleans, Constants, Symbols",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.other.symbol",
        "support.constant"
      ],
      "settings": {
        "foreground": "#c792ea"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#a5e844"
      }
    },
    {
      "name": "Attribute Values (HTML/XML)",
      "scope": [
        "meta.attribute string",
        "string.quoted.double.html",
        "string.quoted.single.html"
      ],
      "settings": {
        "foreground": "#a5e844"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.spread",
        "keyword.operator.rest",
        "keyword.operator.ternary"
      ],
      "settings": {
        "foreground": "#80cbc4"
      }
    },
    {
      "name": "Properties",
      "scope": [
        "support.type.property-name",
        "support.type.property-name.css",
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#80cbc4"
      }
    },
    {
      "name": "CDATA, Char, Inserted",
      "scope": [
        "string.unquoted.cdata",
        "constant.character",
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#80cbc4"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#ff1493"
      }
    },
    {
      "name": "Attribute Names",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#ffcb6b"
      }
    },
    {
      "name": "Builtins, Classes, Types",
      "scope": [
        "support.class.builtin",
        "entity.name.type",
        "support.type",
        "entity.name.class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#ffcb6b"
      }
    },
    {
      "name": "Numbers, Units",
      "scope": [
        "constant.numeric",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#fd9170"
      }
    },
    {
      "name": "CSS At-rules",
      "scope": [
        "keyword.control.at-rule",
        "entity.name.function.scss",
        "meta.at-rule support.type.property-name"
      ],
      "settings": {
        "foreground": "#fd9170"
      }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.name.tag.css",
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#ff00d6"
      }
    },
    {
      "name": "CSS pseudo-class/element",
      "scope": [
        "entity.other.attribute-name.pseudo-class",
        "entity.other.attribute-name.pseudo-element"
      ],
      "settings": {
        "foreground": "#a5e844"
      }
    },
    {
      "name": "Regex, Class Names (special)",
      "scope": [
        "string.regexp",
        "constant.other.color.rgb-value",
        "support.constant.color"
      ],
      "settings": {
        "foreground": "#f2ff00"
      }
    },
    {
      "name": "CSS custom properties",
      "scope": [
        "variable.css",
        "variable.argument.css",
        "variable.parameter.misc.css",
        "support.type.custom-property.css",
        "variable.other.custom-property.css",
        "source.css variable",
        "source.scss variable",
        "source.sass variable"
      ],
      "settings": {
        "foreground": "#80cbc4"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable.language",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#ff6666"
      }
    },
    {
      "name": "Variables (non-CSS)",
      "scope": [
        "variable",
        "variable.other"
      ],
      "settings": {
        "foreground": "#ff6666"
      }
    },
    {
      "name": "Deleted, Entity",
      "scope": [
        "markup.deleted",
        "constant.character.entity",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#ff6666"
      }
    },
    {
      "name": "URL, Link",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#ff6666"
      }
    },
    {
      "name": "Important, Bold",
      "scope": [
        "keyword.other.important",
        "markup.bold"
      ],
      "settings": {
        "foreground": "#c792ea",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Italic (markup)",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Heading",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#ff1493",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Template string interpolation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#ff1493"
      }
    },
    {
      "name": "Embedded expression content",
      "scope": [
        "meta.template.expression",
        "meta.embedded"
      ],
      "settings": {
        "foreground": "#eeeeee"
      }
    },
    {
      "name": "JSON property names",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#80cbc4"
      }
    },
    {
      "name": "JSON string values",
      "scope": [
        "string.quoted.double.json"
      ],
      "settings": {
        "foreground": "#a5e844"
      }
    },
    {
      "name": "YAML keys",
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#80cbc4"
      }
    },
    {
      "name": "Markdown code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#fd9170"
      }
    },
    {
      "name": "Markdown list",
      "scope": [
        "markup.list",
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#ffcb6b"
      }
    },
    {
      "name": "Markdown quote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#888888",
        "fontStyle": "italic"
      }
    },
    {
      "name": "TypeScript/JS type annotations",
      "scope": [
        "support.type.primitive",
        "entity.name.type.alias",
        "entity.name.type.interface",
        "entity.name.type.enum"
      ],
      "settings": {
        "foreground": "#ffcb6b"
      }
    },
    {
      "name": "Decorator",
      "scope": [
        "meta.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#fd9170"
      }
    },
    {
      "name": "CSS property values",
      "scope": [
        "support.constant.property-value.css",
        "meta.property-value.css"
      ],
      "settings": {
        "foreground": "#fd9170"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "enumMember": "#80cbc4",
    "variable": "#ff6666",
    "variable.customProperty": "#80cbc4",
    "variable.constant": "#c792ea",
    "variable.defaultLibrary": "#ffcb6b",
    "variable.parameter": "#ff6666",
    "type": "#ffcb6b",
    "class": "#ffcb6b",
    "interface": "#ffcb6b",
    "enum": "#ffcb6b",
    "typeParameter": "#f2ff00",
    "function": "#c792ea",
    "method": "#c792ea",
    "decorator": "#fd9170",
    "namespace": "#ffcb6b",
    "property": "#80cbc4",
    "parameter": "#ff6666"
  }
}
